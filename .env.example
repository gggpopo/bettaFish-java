# ============================================================
# BettaFish 完整配置文件
# 复制为 .env 后填入你的 API Key 即可启动
# ============================================================

# ==================== LLM 引擎开关 ====================
# 设为 true 并填入 API Key 才能启用对应引擎

# QueryEngine — DeepSeek (新闻搜索分析)
BETTAFISH_LLM_QUERY_ENABLED=true
BETTAFISH_LLM_QUERY_API_KEY=你的DeepSeek_API_Key
BETTAFISH_LLM_QUERY_BASE_URL=https://api.deepseek.com
BETTAFISH_LLM_QUERY_MODEL_NAME=deepseek-chat

# MediaEngine — Gemini 2.5 Pro (多模态分析)
BETTAFISH_LLM_MEDIA_ENABLED=true
BETTAFISH_LLM_MEDIA_API_KEY=你的Gemini_API_Key
BETTAFISH_LLM_MEDIA_BASE_URL=https://aihubmix.com/v1
BETTAFISH_LLM_MEDIA_MODEL_NAME=gemini-2.5-pro

# InsightEngine — Kimi K2 (舆情洞察)
BETTAFISH_LLM_INSIGHT_ENABLED=true
BETTAFISH_LLM_INSIGHT_API_KEY=你的Kimi_API_Key
BETTAFISH_LLM_INSIGHT_BASE_URL=https://api.moonshot.cn/v1
BETTAFISH_LLM_INSIGHT_MODEL_NAME=kimi-k2

# ReportEngine — Gemini 2.5 Pro (报告生成)
BETTAFISH_LLM_REPORT_ENABLED=true
BETTAFISH_LLM_REPORT_API_KEY=你的Gemini_API_Key
BETTAFISH_LLM_REPORT_BASE_URL=https://aihubmix.com/v1
BETTAFISH_LLM_REPORT_MODEL_NAME=gemini-2.5-pro

# ForumHost — Qwen3-235B (论坛主持人)
BETTAFISH_LLM_FORUM_HOST_ENABLED=true
BETTAFISH_LLM_FORUM_HOST_API_KEY=你的SiliconFlow_API_Key
BETTAFISH_LLM_FORUM_HOST_BASE_URL=https://api.siliconflow.cn/v1
BETTAFISH_LLM_FORUM_HOST_MODEL_NAME=Qwen/Qwen3-235B-A22B

# KeywordOptimizer — Qwen3-235B (关键词优化)
BETTAFISH_LLM_KEYWORD_OPTIMIZER_ENABLED=true
BETTAFISH_LLM_KEYWORD_OPTIMIZER_API_KEY=你的SiliconFlow_API_Key
BETTAFISH_LLM_KEYWORD_OPTIMIZER_BASE_URL=https://api.siliconflow.cn/v1
BETTAFISH_LLM_KEYWORD_OPTIMIZER_MODEL_NAME=Qwen/Qwen3-235B-A22B

# MindSpider — DeepSeek (爬虫调度)
BETTAFISH_LLM_MINDSPIDER_ENABLED=true
BETTAFISH_LLM_MINDSPIDER_API_KEY=你的DeepSeek_API_Key
BETTAFISH_LLM_MINDSPIDER_BASE_URL=https://api.deepseek.com
BETTAFISH_LLM_MINDSPIDER_MODEL_NAME=deepseek-chat

# ==================== 搜索服务 ====================

# Tavily — QueryEngine 的新闻搜索
BETTAFISH_TAVILY_API_KEY=你的Tavily_API_Key
BETTAFISH_TAVILY_BASE_URL=https://api.tavily.com
BETTAFISH_TAVILY_MAX_RESULTS=7

# Bocha — MediaEngine 的多模态搜索
BETTAFISH_BOCHA_API_KEY=你的Bocha_API_Key
BETTAFISH_BOCHA_BASE_URL=https://api.bochaai.com/v1

# ==================== 数据库 ====================

# MediaCrawler 数据库 (InsightEngine 使用)
# 如果没有数据库，设 BETTAFISH_DATABASE_SEARCH_ENABLED=false
BETTAFISH_DATABASE_SEARCH_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=bettafish
DB_PASSWORD=bettafish
DB_NAME=media_crawler

# ==================== 情感分析 MCP ====================

BETTAFISH_SENTIMENT_MCP_ENABLED=true
BETTAFISH_SENTIMENT_MCP_BASE_URL=http://localhost:8081

# ==================== 运行参数 ====================

BETTAFISH_ANALYSIS_TASK_TIMEOUT=PT5M
BETTAFISH_ANALYSIS_ENGINE_TIMEOUT=PT90S
BETTAFISH_ANALYSIS_MAX_CONCURRENT_ENGINES=3
